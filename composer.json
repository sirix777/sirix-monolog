{
  "name": "sirix/monolog",
  "description": "Monolog Factories for Mezzio",
  "license": "BSD-2-Clause",
  "type": "library",
  "keywords": [
    "factory",
    "logging",
    "mezzio",
    "monolog",
    "psr-3",
    "psr-11"
  ],
  "require": {
    "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
    "ext-json": "*",
    "monolog/monolog": "^3.10",
    "psr/container": "^1.0 || ^2.0.2",
    "psr/log": "^2.0 || ^3.0.2",
    "sirix/container-resolver": "^0.1.1"
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.9.1",
    "graylog2/gelf-php": "^2.0.0-beta.1",
    "mongodb/mongodb": "^2.1.2",
    "phpunit/phpunit": "^11.5.55",
    "ruflin/elastica": "^7.3.2",
    "sirix/redaction": "^1.3.1"
  },
  "suggest": {
    "graylog2/gelf-php": "Required when using the gelf formatter",
    "mongodb/mongodb": "Required when using the mongo_db formatter",
    "ruflin/elastica": "Required when using the elastica formatter",
    "sirix/redaction": "Required when using the redactor processor"
  },
  "autoload": {
    "psr-4": {
      "Sirix\\Monolog\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sirix\\Test\\Monolog\\": "test/"
    }
  },
  "config": {
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    },
    "bump-after-update": true,
    "sort-packages": true
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": false,
      "forward-command": true,
      "target-directory": "tools"
    }
  },
  "scripts": {
    "analyse-deps": "tools/composer-dependency-analyser/vendor/bin/composer-dependency-analyser",
    "check": [
      "@cs-check",
      "@rector",
      "@phpstan",
      "@test"
    ],
    "cs-check": "php tools/php-cs-fixer/vendor/bin/php-cs-fixer fix -vvv --dry-run --diff",
    "cs-fix": "php tools/php-cs-fixer/vendor/bin/php-cs-fixer fix -vvv",
    "normalize": "@composer bin composer-normalize normalize --diff ../../composer.json",
    "phpstan": "php tools/phpstan/vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=1G",
    "rector": "php tools/rector/vendor/bin/rector process --dry-run --xdebug --memory-limit=1G",
    "rector-fix": "php tools/rector/vendor/bin/rector process --xdebug --memory-limit=1G",
    "test": "phpunit --testdox --colors=always"
  }
}
